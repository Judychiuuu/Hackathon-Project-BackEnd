# ─── Hive Pulse server config ───────────────────────────────────────────────
# Copy this file to ".env" and fill in real values. .env is gitignored.

# DATA SOURCE: "jira" pulls live; "mock" uses the bundled demo dataset.
# If "jira" is set but JIRA_API_TOKEN is missing, the server auto-falls back to mock.
DATA_SOURCE=mock

# ─── Jira (Atlassian Cloud) ───
JIRA_BASE_URL=https://hivefs.atlassian.net
JIRA_EMAIL=ismail.elktiri@hivefs.com
JIRA_API_TOKEN=
JIRA_BOARDS=LO,PAY,UL,ANA,INFRA

# ─── MongoDB Atlas (OPTIONAL) ───
# Leave MONGO_URI blank to run with zero setup (in-memory + data/seed.json only).
MONGO_URI=
MONGO_DB=hivepulse

# ─── Polling / sprint context ───
POLL_CRON=*/5 * * * *
SPRINT_NUMBER=24
SPRINT_WEEK=Jun 10, 2026
SPRINT_LENGTH_DAYS=10
SPRINT_ELAPSED_DAYS=6
TZ_DISPLAY=America/New_York

# ─── Optional LLM narrative (off by default) ───
ENABLE_NARRATIVE=false
ANTHROPIC_API_KEY=

# ─── Server ───
PORT=8787
CORS_ORIGIN=http://localhost:5176
